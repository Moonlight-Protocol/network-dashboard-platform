{
  "name": "@moonlight-protocol/network-dashboard-platform",
  "version": "0.1.3",
  "license": "MIT",
  "exports": "./src/main.ts",
  "tasks": {
    "serve": "deno run --allow-all src/main.ts",
    "test": "deno test --allow-all",
    "test:unit": "deno test --allow-all src/",
    "check": "deno check src/main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@/": "./src/",
    "@oak/oak": "jsr:@oak/oak@^17.1.4",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@stellar/stellar-sdk": "npm:@stellar/stellar-sdk@^15.0.1",
    "stellar-sdk": "npm:@stellar/stellar-sdk@^15.0.1",
    "stellar-sdk/rpc": "npm:@stellar/stellar-sdk@^15.0.1/rpc",
    "chalk": "npm:chalk@^5.3.0"
  }
}
